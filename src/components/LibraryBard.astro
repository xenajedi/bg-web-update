---
---
<section class="w-full py-20 px-4 md:px-8 text-[#0995ce] border-t border-white/5" style="background: linear-gradient(135deg, #0a1c3e 0%, #0798d2 100%);">
  <div class="max-w-6xl mx-auto space-y-24">
    
    <!-- Header -->
    <div class="text-center bards-header opacity-0">
      <h1 class="font-bebas tracking-widest text-5xl md:text-8xl text-white">
        LIBRARY BARDS
      </h1>
      <p class="font-raleway text-lg md:text-xl uppercase tracking-widest font-light text-[#0995ce] mt-2">
        Nerdy Comedy Parody Band
      </p>
      <p class="font-birthstone text-4xl sm:text-5xl text-[#0995ce] mt-4 block">
        "Transforming top hits into the nerdy versions they should have been in the first place."
      </p>
    </div>

    <!-- Album 1: Bombarded -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start bards-album-1 opacity-0">
      <!-- Left: Album Art & Title -->
      <div class="lg:col-span-4 flex flex-col items-center sm:items-start text-center sm:text-left gap-6">
        <div class="relative group w-64 h-64 sm:w-72 sm:h-72 lg:w-full lg:h-auto aspect-square overflow-hidden rounded-lg shadow-2xl border-4 border-[#0995ce]">
          <img src="/lb-bombarded.jpg" alt="Bombarded Album Artwork" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
        </div>
        <div>
          <h3 class="font-bebas tracking-widest text-3xl text-white mb-2">BOMBARDED (2019)</h3>
          <p class="text-sm font-raleway font-light text-white/80">The acclaimed comedy parody album featuring fan-favorites.</p>
        </div>
      </div>
      <!-- Right: Streaming & Videos -->
      <div class="lg:col-span-8 space-y-6">
        <!-- Streaming platforms horizontal -->
        <div class="space-y-3">
          <p class="text-xs uppercase tracking-widest font-bold text-white/70">Listen / Stream On:</p>
          <div class="flex flex-wrap items-center gap-4">
            <a 
              href="https://music.apple.com/us/album/bombarded/1492448145" 
              target="_blank" 
              rel="noopener noreferrer" 
              class="flex items-center gap-2 bg-black/45 hover:bg-black/60 py-2 px-4 rounded-md border border-[#0995ce]/30 hover:scale-105 transition-all duration-300"
            >
              <img src="/apple-music-color.webp" alt="Apple Music" class="h-5 w-auto" />
              <span class="text-xs font-bold text-white font-bebas tracking-wider uppercase">Apple Music</span>
            </a>
            <a 
              href="https://open.spotify.com/album/61fUNbWG6L76yQL8qZzB9K" 
              target="_blank" 
              rel="noopener noreferrer" 
              class="flex items-center gap-2 bg-black/45 hover:bg-black/60 py-2 px-4 rounded-md border border-[#0995ce]/30 hover:scale-105 transition-all duration-300"
            >
              <img src="/spotify-color.png" alt="Spotify" class="h-5 w-auto" />
              <span class="text-xs font-bold text-white font-bebas tracking-wider uppercase">Spotify</span>
            </a>
            <a 
              href="https://librarybards.bandcamp.com/album/bombarded" 
              target="_blank" 
              rel="noopener noreferrer" 
              class="flex items-center gap-2 bg-black/45 hover:bg-black/60 py-2 px-4 rounded-md border border-[#0995ce]/30 hover:scale-105 transition-all duration-300"
            >
              <img src="/bandcamp-color.png" alt="Bandcamp" class="h-5 w-auto" />
              <span class="text-xs font-bold text-white font-bebas tracking-wider uppercase">Bandcamp</span>
            </a>
          </div>
        </div>

        <h4 class="font-bebas tracking-widest text-xl text-white uppercase opacity-75 pt-2">Music Videos from Bombarded:</h4>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="flex flex-col">
            <div class="relative w-full aspect-video rounded-lg overflow-hidden border border-[#0995ce]/40 shadow-xl bg-black">
              <iframe 
                src="https://www.youtube.com/embed/gioq-N_ZWwI" 
                title="Bombarded Video 1" 
                allowfullscreen 
                class="absolute inset-0 w-full h-full border-0"
              ></iframe>
            </div>
            <span class="text-xs uppercase tracking-widest text-white/60 mt-2 text-center">Video Reel 1</span>
          </div>
          <div class="flex flex-col">
            <div class="relative w-full aspect-video rounded-lg overflow-hidden border border-[#0995ce]/40 shadow-xl bg-black">
              <iframe 
                src="https://www.youtube.com/embed/Y1SQ3wh0TNU" 
                title="Bombarded Video 2" 
                allowfullscreen 
                class="absolute inset-0 w-full h-full border-0"
              ></iframe>
            </div>
            <span class="text-xs uppercase tracking-widest text-white/60 mt-2 text-center">Video Reel 2</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Album 2: Bardcore -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start bards-album-2 opacity-0 pt-12 border-t border-white/10">
      <!-- Left: Album Art & Title -->
      <div class="lg:col-span-4 flex flex-col items-center sm:items-start text-center sm:text-left gap-6">
        <div class="relative group w-64 h-64 sm:w-72 sm:h-72 lg:w-full lg:h-auto aspect-square overflow-hidden rounded-lg shadow-2xl border-4 border-[#0995ce]">
          <img src="/lb-bardcore.jpg" alt="Bardcore Album Artwork" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
        </div>
        <div>
          <h3 class="font-bebas tracking-widest text-3xl text-white mb-2">BARDCORE (2017)</h3>
          <p class="text-sm font-raleway font-light text-white/80">The breakout parody collection that started it all.</p>
        </div>
      </div>
      <!-- Right: Streaming & Videos -->
      <div class="lg:col-span-8 space-y-6">
        <!-- Streaming platforms horizontal -->
        <div class="space-y-3">
          <p class="text-xs uppercase tracking-widest font-bold text-white/70">Listen / Stream On:</p>
          <div class="flex flex-wrap items-center gap-4">
            <a 
              href="https://music.apple.com/us/album/bardcore/1266812479" 
              target="_blank" 
              rel="noopener noreferrer" 
              class="flex items-center gap-2 bg-black/45 hover:bg-black/60 py-2 px-4 rounded-md border border-[#0995ce]/30 hover:scale-105 transition-all duration-300"
            >
              <img src="/apple-music-color.webp" alt="Apple Music" class="h-5 w-auto" />
              <span class="text-xs font-bold text-white font-bebas tracking-wider uppercase">Apple Music</span>
            </a>
            <a 
              href="https://open.spotify.com/album/4fvtTBen9Ag0CXiAxcVTJE" 
              target="_blank" 
              rel="noopener noreferrer" 
              class="flex items-center gap-2 bg-black/45 hover:bg-black/60 py-2 px-4 rounded-md border border-[#0995ce]/30 hover:scale-105 transition-all duration-300"
            >
              <img src="/spotify-color.png" alt="Spotify" class="h-5 w-auto" />
              <span class="text-xs font-bold text-white font-bebas tracking-wider uppercase">Spotify</span>
            </a>
            <a 
              href="https://librarybards.bandcamp.com/album/bardcore" 
              target="_blank" 
              rel="noopener noreferrer" 
              class="flex items-center gap-2 bg-black/45 hover:bg-black/60 py-2 px-4 rounded-md border border-[#0995ce]/30 hover:scale-105 transition-all duration-300"
            >
              <img src="/bandcamp-color.png" alt="Bandcamp" class="h-5 w-auto" />
              <span class="text-xs font-bold text-white font-bebas tracking-wider uppercase">Bandcamp</span>
            </a>
          </div>
        </div>

        <h4 class="font-bebas tracking-widest text-xl text-white uppercase opacity-75 pt-2">Music Videos from Bardcore:</h4>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="flex flex-col">
            <div class="relative w-full aspect-video rounded-lg overflow-hidden border border-[#0995ce]/40 shadow-xl bg-black">
              <iframe 
                src="https://www.youtube.com/embed/R7i-Cg5DiWo" 
                title="Bardcore Video 1" 
                allowfullscreen 
                class="absolute inset-0 w-full h-full border-0"
              ></iframe>
            </div>
            <span class="text-xs uppercase tracking-widest text-white/60 mt-2 text-center">Video Reel 3</span>
          </div>
          <div class="flex flex-col">
            <div class="relative w-full aspect-video rounded-lg overflow-hidden border border-[#0995ce]/40 shadow-xl bg-black">
              <iframe 
                src="https://www.youtube.com/embed/luzIAxg-EvU" 
                title="Bardcore Video 2" 
                allowfullscreen 
                class="absolute inset-0 w-full h-full border-0"
              ></iframe>
            </div>
            <span class="text-xs uppercase tracking-widest text-white/60 mt-2 text-center">Video Reel 4</span>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  window.addEventListener('DOMContentLoaded', () => {
    // Header fade-in
    gsap.to('.bards-header', {
      scrollTrigger: {
        trigger: '.bards-header',
        start: 'top 85%',
        toggleActions: 'play none none none'
      },
      opacity: 1,
      y: 0,
      duration: 1.0,
      ease: 'power3.out'
    });

    // Album 1 fade-in
    gsap.to('.bards-album-1', {
      scrollTrigger: {
        trigger: '.bards-album-1',
        start: 'top 85%',
        toggleActions: 'play none none none'
      },
      opacity: 1,
      y: 0,
      duration: 1.2,
      ease: 'power3.out'
    });

    // Album 2 fade-in
    gsap.to('.bards-album-2', {
      scrollTrigger: {
        trigger: '.bards-album-2',
        start: 'top 85%',
        toggleActions: 'play none none none'
      },
      opacity: 1,
      y: 0,
      duration: 1.2,
      ease: 'power3.out'
    });
  });
</script>
