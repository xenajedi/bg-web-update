---
const events = [
  {
    dateRange: "July 22 - 26, 2026",
    title: "San Diego Comic-Con",
    location: "San Diego, CA",
    link: "https://www.comic-con.org/cc/",
    btnText: "Event Info"
  },
  {
    dateRange: "July 30 - August 2, 2026",
    title: "GenCon",
    location: "Indianapolis, IN",
    link: "https://www.gencon.com",
    btnText: "Buy Tickets"
  },
  {
    dateRange: "August 5 - 9, 2026",
    title: "Star Trek Las Vegas",
    location: "Las Vegas, NV",
    link: "https://www.creationent.com/events/stlv-26/",
    btnText: "Event Details"
  }
];
---
<section class="w-full py-16 px-4 md:px-8 min-h-screen text-[#5170ff]" style="background: linear-gradient(135deg, #0c1e20 0%, #403433 100%);">
  <div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-16 schedule-header opacity-0">
      <h1 class="font-bebas tracking-widest text-5xl md:text-8xl text-[#5170ff]">
        APPEARANCES
      </h1>
      <p class="font-raleway text-lg md:text-xl uppercase tracking-widest font-light text-[#5170ff]/80 mt-2">
        2026 Shows & Tour Dates
      </p>
    </div>

    <!-- Main Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      
      <!-- Left Side: Schedule Cards -->
      <div class="lg:col-span-7 space-y-6 schedule-list opacity-0">
        <h2 class="font-bebas tracking-widest text-3xl md:text-4xl text-white mb-6 uppercase border-b border-[#5170ff]/30 pb-2">
          Upcoming Events
        </h2>
        
        <div class="space-y-4">
          {events.map((event) => (
            <div class="bg-black/35 hover:bg-black/50 p-5 rounded-lg border border-[#5170ff]/20 hover:border-[#5170ff]/50 transition-all duration-300 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 group">
              <div class="space-y-1">
                <span class="text-xs uppercase tracking-widest font-bold text-[#5170ff]/80 block">{event.dateRange}</span>
                <h3 class="font-bebas tracking-wider text-2xl md:text-3xl text-white group-hover:text-[#5170ff] transition-colors">{event.title}</h3>
                <p class="text-sm font-raleway font-light text-white/70">{event.location}</p>
              </div>
              <a 
                href={event.link} 
                target="_blank" 
                rel="noopener noreferrer" 
                class="font-bebas tracking-widest text-sm py-2 px-5 rounded bg-[#5170ff] hover:bg-white text-black font-semibold uppercase transition-all duration-300 shadow hover:shadow-md self-stretch sm:self-auto text-center"
              >
                {event.btnText}
              </a>
            </div>
          ))}
          
          <!-- Additional Events Note -->
          <div class="p-6 text-center border-2 border-dashed border-[#5170ff]/20 rounded-lg">
            <span class="font-bebas tracking-widest text-xl text-white/80 block uppercase">Additional Events Coming Soon</span>
            <span class="text-xs font-raleway text-white/50">Stay tuned for more updates!</span>
          </div>
        </div>
      </div>

      <!-- Right Side: Image -->
      <div class="lg:col-span-5 flex justify-center schedule-img opacity-0">
        <div class="relative group w-full max-w-sm lg:max-w-full">
          <!-- Offset border -->
          <div class="absolute -inset-3 border-2 border-[#5170ff]/40 rounded-lg translate-x-2 translate-y-2 group-hover:translate-x-0 group-hover:translate-y-0 transition-transform duration-300"></div>
          <!-- Main Image -->
          <img 
            src="/bg-appearances.webp" 
            alt="Bonnie Gordon Live Appearance" 
            class="relative z-10 w-full h-auto object-cover rounded-lg shadow-2xl border-4 border-[#5170ff] transition-transform duration-300"
          />
        </div>
      </div>

    </div>

  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  window.addEventListener('DOMContentLoaded', () => {
    // Header fade-in
    gsap.to('.schedule-header', {
      opacity: 1,
      y: 0,
      duration: 1.0,
      ease: 'power3.out'
    });

    // Left section slide-in
    gsap.to('.schedule-list', {
      scrollTrigger: {
        trigger: '.schedule-list',
        start: 'top 85%',
        toggleActions: 'play none none none'
      },
      opacity: 1,
      y: 0,
      duration: 1.2,
      ease: 'power3.out'
    });

    // Right section slide-in
    gsap.to('.schedule-img', {
      scrollTrigger: {
        trigger: '.schedule-img',
        start: 'top 85%',
        toggleActions: 'play none none none'
      },
      opacity: 1,
      y: 0,
      duration: 1.2,
      ease: 'power3.out'
    });
  });
</script>
