---
---
<section class="w-full py-16 px-4 md:px-8 min-h-screen text-[#c0936f]" style="background-color: #4d1614;">
  <div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-16 actor-header opacity-0">
      <h1 class="font-bebas tracking-widest text-5xl md:text-8xl text-[#c0936f]">
        STAGE & SCREEN
      </h1>
      <p class="font-raleway text-lg md:text-xl uppercase tracking-widest font-light text-[#c0936f]/80 mt-2">
        Portfolio & Acting Credits
      </p>
    </div>

    <!-- Main Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
      
      <!-- Left Side: Resumes -->
      <div class="lg:col-span-7 space-y-12 credits-container opacity-0">
        
        <!-- Stage & Screen section -->
        <div>
          <h2 class="font-bebas tracking-widest text-3xl md:text-4xl border-b border-[#c0936f]/40 pb-2 mb-6 uppercase">
            On Screen & Live Stage
          </h2>
          <div class="space-y-4">
            <div class="flex justify-between items-center py-2 border-b border-[#c0936f]/10">
              <div>
                <h3 class="font-semibold text-white text-base md:text-lg">The Vanishing Tour</h3>
                <p class="text-xs uppercase tracking-wider text-[#c0936f]/80">Film / Digital</p>
              </div>
              <span class="text-sm md:text-base font-medium italic">Frannie</span>
            </div>
            
            <div class="flex justify-between items-center py-2 border-b border-[#c0936f]/10">
              <div>
                <h3 class="font-semibold text-white text-base md:text-lg">The Quest</h3>
                <p class="text-xs uppercase tracking-wider text-[#c0936f]/80">ABC Family</p>
              </div>
              <span class="text-sm md:text-base font-medium italic">Paladin Bonnie</span>
            </div>
            
            <div class="flex justify-between items-center py-2 border-b border-[#c0936f]/10">
              <div>
                <h3 class="font-semibold text-white text-base md:text-lg">Teaching a Robot to Love</h3>
                <p class="text-xs uppercase tracking-wider text-[#c0936f]/80">Hollywood Fringe</p>
              </div>
              <span class="text-sm md:text-base font-medium italic">Lead Cast</span>
            </div>
            
            <div class="flex justify-between items-center py-2 border-b border-[#c0936f]/10">
              <div>
                <h3 class="font-semibold text-white text-base md:text-lg">Unnamed Show</h3>
                <p class="text-xs uppercase tracking-wider text-[#c0936f]/80">London's West End</p>
              </div>
              <span class="text-sm md:text-base font-medium italic">Principal Performer</span>
            </div>
          </div>
        </div>

        <!-- Voiceover Section -->
        <div>
          <h2 class="font-bebas tracking-widest text-3xl md:text-4xl border-b border-[#c0936f]/40 pb-2 mb-6 uppercase">
            Voice Acting & Video Games
          </h2>
          <div class="space-y-4">
            <div class="flex justify-between items-center py-2 border-b border-[#c0936f]/10">
              <div>
                <h3 class="font-semibold text-white text-base md:text-lg">Star Trek: Prodigy</h3>
                <p class="text-xs uppercase tracking-wider text-[#c0936f]/80">Paramount+ / Nickelodeon</p>
              </div>
              <span class="text-sm md:text-base font-medium italic text-right">Ship's Computer / Multiple</span>
            </div>
            
            <div class="flex justify-between items-center py-2 border-b border-[#c0936f]/10">
              <div>
                <h3 class="font-semibold text-white text-base md:text-lg">Street Fighter V</h3>
                <p class="text-xs uppercase tracking-wider text-[#c0936f]/80">Capcom</p>
              </div>
              <span class="text-sm md:text-base font-medium italic">Rainbow Mika (Rainbow Mike)</span>
            </div>
            
            <div class="flex justify-between items-center py-2 border-b border-[#c0936f]/10">
              <div>
                <h3 class="font-semibold text-white text-base md:text-lg">Fire Emblem Series</h3>
                <p class="text-xs uppercase tracking-wider text-[#c0936f]/80">Nintendo / Intelligent Systems</p>
              </div>
              <span class="text-sm md:text-base font-medium italic">Silque</span>
            </div>
            
            <div class="flex justify-between items-center py-2 border-b border-[#c0936f]/10">
              <div>
                <h3 class="font-semibold text-white text-base md:text-lg">Mega Man 11</h3>
                <p class="text-xs uppercase tracking-wider text-[#c0936f]/80">Capcom</p>
              </div>
              <span class="text-sm md:text-base font-medium italic">Bounce Man</span>
            </div>
            
            <div class="flex justify-between items-center py-2 border-b border-[#c0936f]/10">
              <div>
                <h3 class="font-semibold text-white text-base md:text-lg">Code Vein</h3>
                <p class="text-xs uppercase tracking-wider text-[#c0936f]/80">Bandai Namco Studios</p>
              </div>
              <span class="text-sm md:text-base font-medium italic">Eva</span>
            </div>
          </div>
        </div>

      </div>

      <!-- Right Side: Portrait Image -->
      <div class="lg:col-span-5 flex justify-center actor-img opacity-0">
        <div class="relative group w-full max-w-sm lg:max-w-full">
          <!-- Main Image -->
          <img 
            src="/bg-stage.webp" 
            alt="Bonnie Gordon Acting Promo" 
            class="relative z-10 w-full h-auto object-cover rounded-lg shadow-2xl border-4 border-[#c0936f] group-hover:scale-105 transition-transform duration-300"
          />
        </div>
      </div>
      
    </div>

    <!-- Video Reel / Embeds Section -->
    <div class="mt-24 space-y-12 videos-container opacity-0">
      <h2 class="font-bebas tracking-widest text-4xl md:text-5xl text-center border-b border-[#c0936f]/40 pb-4 max-w-md mx-auto uppercase">
        Featured Performance Reels
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-8">
        <!-- YouTube Embed 1 -->
        <div class="flex flex-col">
          <div class="relative w-full aspect-video rounded-lg overflow-hidden shadow-2xl border-2 border-[#c0936f]/50">
            <iframe 
              src="https://www.youtube.com/embed/Ro_2VpUOv9k" 
              title="Bonnie Gordon acting reel upper" 
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
              allowfullscreen
              class="absolute inset-0 w-full h-full border-0"
            ></iframe>
          </div>
          <span class="text-xs md:text-sm uppercase tracking-wider text-[#c0936f]/70 mt-3 text-center">Featured Work / Demo Reel 1</span>
        </div>
        
        <!-- YouTube Embed 2 -->
        <div class="flex flex-col">
          <div class="relative w-full aspect-video rounded-lg overflow-hidden shadow-2xl border-2 border-[#c0936f]/50">
            <iframe 
              src="https://www.youtube.com/embed/YJ0vCUrxhy0" 
              title="Bonnie Gordon acting reel lower" 
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
              allowfullscreen
              class="absolute inset-0 w-full h-full border-0"
            ></iframe>
          </div>
          <span class="text-xs md:text-sm uppercase tracking-wider text-[#c0936f]/70 mt-3 text-center">Featured Work / Demo Reel 2</span>
        </div>
      </div>
    </div>

  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  window.addEventListener('DOMContentLoaded', () => {
    // Header fade-in
    gsap.to('.actor-header', {
      opacity: 1,
      y: 0,
      duration: 1.0,
      ease: 'power3.out'
    });

    // Main layouts slide/fade
    gsap.to('.credits-container', {
      scrollTrigger: {
        trigger: '.credits-container',
        start: 'top 85%',
        toggleActions: 'play none none none'
      },
      opacity: 1,
      y: 0,
      duration: 1.2,
      ease: 'power3.out'
    });

    gsap.to('.actor-img', {
      scrollTrigger: {
        trigger: '.actor-img',
        start: 'top 85%',
        toggleActions: 'play none none none'
      },
      opacity: 1,
      y: 0,
      duration: 1.2,
      ease: 'power3.out'
    });

    gsap.to('.videos-container', {
      scrollTrigger: {
        trigger: '.videos-container',
        start: 'top 85%',
        toggleActions: 'play none none none'
      },
      opacity: 1,
      y: 0,
      duration: 1.2,
      ease: 'power3.out'
    });
  });
</script>
