---
---
<section class="w-full py-16 px-4 md:px-8 text-[#0995ce]" style="background: linear-gradient(135deg, #0c1e20 0%, #0a1c3e 100%);">
  <div class="max-w-6xl mx-auto">
    
    <!-- Title -->
    <div class="text-center mb-16 conartist-header opacity-0">
      <h1 class="font-bebas tracking-widest text-5xl md:text-8xl text-[#0995ce]">
        SOLO MUSIC
      </h1>
      <p class="font-raleway text-lg md:text-xl uppercase tracking-widest font-light text-[#0995ce]/80 mt-2">
        Bonnie Gordon Solo Projects
      </p>
    </div>

    <!-- Album Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
      
      <!-- Left Side: Album Art -->
      <div class="lg:col-span-5 flex justify-center conartist-img opacity-0">
        <div class="relative group w-full max-w-sm lg:max-w-full">
          <!-- Main Image -->
          <img 
            src="/bg-conartist.webp" 
            alt="Con Artist Album Cover" 
            class="relative z-10 w-full h-auto object-cover rounded-lg shadow-2xl border-4 border-[#0995ce] group-hover:scale-105 transition-transform duration-300"
          />
        </div>
      </div>

      <!-- Right Side: Details & Streaming -->
      <div class="lg:col-span-7 space-y-6 conartist-details opacity-0">
        <h2 class="font-bebas tracking-widest text-4xl md:text-5xl text-white uppercase">
          Con Artist (2023)
        </h2>
        
        <!-- Fancy Birthstone Quote -->
        <p class="font-birthstone text-5xl sm:text-6xl text-[#0995ce] leading-none my-4 transform -rotate-1 origin-left block select-none">
          "Jazzy with a touch of nerdy"
        </p>

        <p class="font-raleway text-base md:text-lg leading-relaxed font-light text-[#0995ce]/90">
          Bonnie’s first solo album, <span class="font-semibold text-white">Con Artist</span>, is available on all major streaming platforms. Combining classic jazz influences with playful, geeky themes, the album highlights her songwriting and soulful vocal range in a truly unique musical showcase.
        </p>

        <!-- Streaming platforms -->
        <div class="space-y-4">
          <p class="text-xs uppercase tracking-widest font-bold text-white/70">Listen / Stream On:</p>
          <div class="flex flex-wrap items-center gap-6">
            <a 
              href="https://music.apple.com/us/album/con-artist/1680243898" 
              target="_blank" 
              rel="noopener noreferrer"
              class="transition-all duration-300 hover:scale-110 flex items-center gap-2 bg-white/5 hover:bg-white/10 py-2 px-4 rounded-md border border-[#0995ce]/20"
            >
              <img src="/apple-music-color.webp" alt="Apple Music" class="h-6 w-auto object-contain" />
              <span class="text-xs font-semibold text-white font-bebas tracking-wider uppercase">Apple Music</span>
            </a>

            <a 
              href="https://open.spotify.com/album/2z7LyAoPZ2kh9wZLe6V1Qa" 
              target="_blank" 
              rel="noopener noreferrer"
              class="transition-all duration-300 hover:scale-110 flex items-center gap-2 bg-white/5 hover:bg-white/10 py-2 px-4 rounded-md border border-[#0995ce]/20"
            >
              <img src="/spotify-color.png" alt="Spotify" class="h-6 w-auto object-contain" />
              <span class="text-xs font-semibold text-white font-bebas tracking-wider uppercase">Spotify</span>
            </a>

            <a 
              href="https://bonniegordon.bandcamp.com/album/con-artist" 
              target="_blank" 
              rel="noopener noreferrer"
              class="transition-all duration-300 hover:scale-110 flex items-center gap-2 bg-white/5 hover:bg-white/10 py-2 px-4 rounded-md border border-[#0995ce]/20"
            >
              <img src="/bandcamp-color.png" alt="Bandcamp" class="h-6 w-auto object-contain" />
              <span class="text-xs font-semibold text-white font-bebas tracking-wider uppercase">Bandcamp</span>
            </a>

            <a 
              href="https://tidal.com/album/286474488" 
              target="_blank" 
              rel="noopener noreferrer"
              class="transition-all duration-300 hover:scale-110 flex items-center gap-2 bg-white/5 hover:bg-white/10 py-2 px-4 rounded-md border border-[#0995ce]/20"
            >
              <img src="/tidal-color.png" alt="Tidal" class="h-6 w-auto object-contain" />
              <span class="text-xs font-semibold text-white font-bebas tracking-wider uppercase">Tidal</span>
            </a>
          </div>
        </div>

      </div>

    </div>

    <!-- Centered Video Embed below -->
    <div class="mt-16 max-w-3xl mx-auto conartist-video opacity-0">
      <div class="relative w-full aspect-video rounded-lg overflow-hidden shadow-2xl border border-[#0995ce]/30">
        <iframe 
          src="https://www.youtube.com/embed/4FMKatC65JQ" 
          title="Con Artist Featured Music Video" 
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
          allowfullscreen
          class="absolute inset-0 w-full h-full border-0"
        ></iframe>
      </div>
    </div>

  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  window.addEventListener('DOMContentLoaded', () => {
    // Header fade-in
    gsap.to('.conartist-header', {
      opacity: 1,
      y: 0,
      duration: 1.0,
      ease: 'power3.out'
    });

    // Image/details fade-in
    gsap.to('.conartist-img', {
      scrollTrigger: {
        trigger: '.conartist-img',
        start: 'top 85%',
        toggleActions: 'play none none none'
      },
      opacity: 1,
      y: 0,
      duration: 1.2,
      ease: 'power3.out'
    });

    gsap.to('.conartist-details', {
      scrollTrigger: {
        trigger: '.conartist-details',
        start: 'top 85%',
        toggleActions: 'play none none none'
      },
      opacity: 1,
      y: 0,
      duration: 1.2,
      ease: 'power3.out'
    });

    gsap.to('.conartist-video', {
      scrollTrigger: {
        trigger: '.conartist-video',
        start: 'top 85%',
        toggleActions: 'play none none none'
      },
      opacity: 1,
      y: 0,
      duration: 1.2,
      ease: 'power3.out'
    });
  });
</script>
